{
  "expo": {
    "name": "bta",
    "slug": "bta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "btaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Приложению BTA Assist необходим доступ к камере для фотографирования зон инъецирования.",
        "NSMicrophoneUsageDescription": "Приложению BTA Assist необходим доступ к микрофону для записи видео.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.falkonpawl.btaapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.falkonpawl.btaapp",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Приложению BTA Assist необходим доступ к камере для фотографирования зон инъецирования.",
          "microphonePermission": "Приложению BTA Assist необходим доступ к микрофону для записи видео."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложению BTA Assist необходим доступ к фотографиям для выбора изображений.",
          "cameraPermission": "Приложению BTA Assist необходим доступ к камере для фотографирования зон инъецирования."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-router"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "runtimeVersion": "exposdk:54.0.0",
    "extra": {
      "router": {}
    }
  }
}
